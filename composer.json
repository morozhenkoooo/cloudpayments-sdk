{
    "name": "morozhenkoooo/cloudpayments-sdk",
    "description": "Modern, strictly-typed PHP 8.3+ SDK for the CloudPayments API — immutable DTOs, native enums, PSR-18 HTTP client, full coverage (payments, 3DS, tokens, subscriptions, 54-FZ receipts, payouts, webhooks).",
    "type": "library",
    "keywords": ["cloudpayments", "payments", "payment-gateway", "sdk", "psr-18", "54-fz", "acquiring"],
    "license": "MIT",
    "homepage": "https://github.com/morozhenkoooo/cloudpayments-sdk",
    "authors": [
        {
            "name": "Dmitriy Kuzmin",
            "homepage": "https://github.com/morozhenkoooo"
        }
    ],
    "support": {
        "issues": "https://github.com/morozhenkoooo/cloudpayments-sdk/issues",
        "source": "https://github.com/morozhenkoooo/cloudpayments-sdk"
    },
    "require": {
        "php": ">=8.3",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "guzzlehttp/guzzle": "^7.9",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CloudPayments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CloudPayments\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --diff",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "check": ["@cs:check", "@stan", "@test"]
    },
    "scripts-descriptions": {
        "test": "Run the PHPUnit test suite",
        "stan": "Run PHPStan static analysis",
        "cs": "Fix code style with php-cs-fixer",
        "check": "Run style check, static analysis and tests"
    }
}
